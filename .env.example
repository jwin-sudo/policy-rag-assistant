OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.6-plus:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=policy-rag-assistant
OPENROUTER_HTTP_REFERER=http://localhost:8000

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB_DIR=./data/chroma
CORPUS_DIR=./corpus
TOP_K=5
RETRIEVAL_FETCH_K=10
PROMPT_K=2
CHUNK_SIZE=900
CHUNK_OVERLAP=120
RANDOM_SEED=42
MAX_ANSWER_WORDS=180
MAX_CONTEXT_CHARS=650
MAX_CITATIONS=2
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=220

OTEL_ENABLED=false
OTEL_SERVICE_NAME=policy-rag-assistant
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATIO=1.0
